// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  CUSTOMER
}

enum PaymentMethodType {
  QRIS
  GOPAY
  OVO
  DANA
  LINKAJA
  SHOPEEPAY
  CASH
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderSource {
  QR_MENU
  POS
  GRABFOOD
  GOFOOD
  SHOPEEFOOD
  OTHER
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum StockMovementType {
  STOCK_IN
  SALE
  RETURN_GOOD
  RETURN_DAMAGED
  ADJUSTMENT
  CORRECTION
  WASTE
}

enum ItemDisposition {
  GOOD
  DAMAGED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  password  String?
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // SSO & 2FA
  googleId           String? @unique
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String?

  // Relations
  restaurants   Restaurant[]
  orders        Order[]
  refreshTokens RefreshToken[]
  deletedAt     DateTime?

  // Reset Password
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  auditLogs AuditLog[]
}

model Restaurant {
  id            String    @id @default(cuid())
  name          String
  description   String?
  address       String?
  detailAddress String? // For manually entered detailed address
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?
  phone         String?
  email         String?
  logo          String?
  banner        String?
  theme         String?   @default("modern-emerald")
  package       String?   @default("FREE_TRIAL")
  status        String    @default("PENDING")
  slug          String    @unique
  isActive      Boolean   @default(true)
  activeUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Feature Management
  enabledFeatures String[] @default([]) // ["CUSTOM_INVOICE", "ADVANCED_STOCK", "WA_NOTIF"]

  // Limits
  maxMenuItems    Int?    @default(15) // Default for Free
  maxAdmins       Int? // Subscription Limits
  allowBranches   Boolean @default(false)
  maxBranches     Int?    @default(0) // 0 = Unlimited, or specific count
  maxStaff        Int?    @default(0)
  maxCategories   Int?    @default(5)
  allowMaps       Boolean @default(false)
  enableAnalytics Boolean @default(false)
  printerSettings Json? // { paperSize: "58mm" | "80mm", autoPrint: boolean, ... }
  invoiceSettings Json? // { npwp: string, prefix: string, footer: string, signature: string }
  slugChangeCount Int     @default(0)
  maxSlugChanges  Int     @default(3)

  // Tax & Discount Settings
  taxRate      Float @default(0) // Percentage, e.g. 11 for 11%
  discountRate Float @default(0) // Percentage, e.g. 10 for 10%

  // Relations
  adminId          String
  admin            User                  @relation(fields: [adminId], references: [id])
  freeTrialEndsAt  DateTime?
  parentId         String? // For Multi-branch support
  parent           Restaurant?           @relation("BranchParent", fields: [parentId], references: [id])
  branches         Restaurant[]          @relation("BranchParent")
  categories       Category[]
  menuItems        MenuItem[]
  paymentMethods   PaymentMethod[]
  orders           Order[]
  returns          Return[]
  stockMovements   StockMovement[]
  helpdeskMessages HelpdeskMessage[]
  deletedAt        DateTime? // Soft Delete for Restaurant
  subscriptionPayments SubscriptionPayment[]
}

model Category {
  id           String    @id @default(cuid())
  name         String
  description  String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]
}

model MenuItem {
  id           String    @id @default(cuid())
  name         String
  description  String?
  price        Float
  image        String?
  isAvailable  Boolean   @default(true)
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  displayName   String?
  isBestSeller  Boolean @default(false)
  isRecommended Boolean @default(false)

  // Stock Management
  isStockManaged    Boolean   @default(false)
  stock             Int       @default(0)
  lowStockThreshold Int       @default(5)
  expiryDate        DateTime?
  taxRate           Float     @default(0)

  // Relations
  restaurantId   String
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  stockMovements StockMovement[]
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  invoiceNumber  String?       @unique
  invoiceDate    DateTime?
  totalAmount    Float
  notes          String?
  tableNumber    String?
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)
  orderSource    OrderSource   @default(QR_MENU)
  adminNotes     String?
  taxAmount      Float         @default(0)
  discountAmount Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  customerId   String
  customer     User        @relation(fields: [customerId], references: [id])
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  payment      Payment?
  returns      Return[]
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  price     Float
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem     @relation(fields: [menuItemId], references: [id])
  returnItems ReturnItem[]
}

model Return {
  id           String       @id @default(cuid())
  returnNumber String       @unique
  reason       String?
  status       ReturnStatus @default(PENDING)
  totalRefund  Float        @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  returnItems  ReturnItem[]
}

model ReturnItem {
  id          String          @id @default(cuid())
  quantity    Int
  price       Float // Price at time of return
  disposition ItemDisposition @default(GOOD) // GOOD = back to stock, DAMAGED = waste
  notes       String?

  // Relations
  returnId    String
  return      Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

model StockMovement {
  id           String            @id @default(cuid())
  type         StockMovementType
  quantity     Int
  previousStock Int
  newStock     Int
  reason       String?
  expiryDate   DateTime?
  createdAt    DateTime          @default(now())

  // Relations
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id            String            @id @default(cuid())
  type          PaymentMethodType
  isActive      Boolean           @default(true)
  qrCode        String?
  merchantId    String?
  accountNumber String?
  accountName   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  // Relations
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  payments     Payment[]
}

model Payment {
  id            String            @id @default(cuid())
  amount        Float
  type          PaymentMethodType
  status        PaymentStatus     @default(PENDING)
  transactionId String?
  paymentDate   DateTime?
  receiptData   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  orderId  String        @unique
  order    Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  methodId String
  method   PaymentMethod @relation(fields: [methodId], references: [id])
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  description     String
  price           Float
  price3Months    Float?
  price6Months    Float?
  price12Months   Float?
  menuLimit       Int
  maxCategories   Int?     @default(10)
  allowMaps       Boolean  @default(false)
  enableAnalytics Boolean  @default(false)
  features        String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key   String @id
  value String
}

model Announcement {
  id        String   @id @default(cuid())
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpdeskMessage {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  senderRole   UserRole
  message      String
  attachment   String?
  readAt       DateTime?
  createdAt    DateTime   @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String?
  details    Json?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  REJECTED
}

model SubscriptionPayment {
  id             String                    @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  planName       String
  amount         Float
  method         String                    @default("BANK_TRANSFER") // BANK_TRANSFER | QRIS | MIDTRANS
  status         SubscriptionPaymentStatus @default(PENDING)
  proofImageUrl  String?
  notes          String?
  // Midtrans metadata (optional)
  orderId        String?
  snapToken      String?
  redirectUrl    String?
  paymentType    String?
  paymentChannel String?
  cycleMonths    Int?
  grossAmount    Float?
  midtransStatus String?
  paidAt         DateTime?
  expiredAt      DateTime?
  validatedAt    DateTime?
  validatedBy    String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}
